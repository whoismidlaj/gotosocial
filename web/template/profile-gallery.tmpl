{{- define "webVisibility" -}}
{{- with .account.WebVisibility -}}
{{- if eq . "public" -}}
public
{{- else if eq . "unlisted" -}}
public and unlisted
{{- end -}}
{{- end -}}
{{- end -}}

{{- with . }}
<main class="profile h-card">
    {{- with . }}
    {{- include "profile_header.tmpl" . | indent 1 }}
    {{- end }}
    {{- with . }}
    {{- include "profile_about_user.tmpl" . | indent 1 }}
    {{- end }}
    {{- if eq .account.WebVisibility "none" }}
    <section data-nosnippet class="nothinghere" aria-labelledby="mediaby">
        <h3 id="mediaby">Media by <b>{{ .account.Username }}</b></h3>
        <p><b>{{ .account.Username }}</b> does not show media on the World Wide Web.</p>
        <p>To see media by <b>{{ .account.Username }}</b>, try pasting this profile URL into your fedi client of choice:</p>
        <pre class="language-url"><code class="language-url">{{- .account.URL -}}</code></pre>
    </section>
    {{- else }}
    <div
        class="media-galleries-wrapper"
        role="region"
        aria-label="Media by {{ .account.Username -}}"
    >
        {{- if .pinned_statuses }}
        <section class="pinned h-feed" aria-labelledby="pinned">
            <div class="col-header">
                <h3 class="p-name" id="pinned">Pinned {{ template "webVisibility" . }} media</h3>
                <a href="#recent">jump to recent</a>
            </div>
            <div
                class="media-gallery photoswipe-gallery"
                role="group"
            >
                {{- range $index, $attachment := .pinnedGalleryItems }}
                {{- includeIndex "status_attachment.tmpl" $attachment $index | indent 4 }}
                {{- end }}
            </div>
        </section>
        {{- end }}
        <section class="recent h-feed" aria-labelledby="recent">
            <div class="col-header wrapping">
                <h3 class="p-name" id="recent">Recent {{ template "webVisibility" . }} media</h3>
                {{- if .excludeBoostsLink }}
                <a href="{{- .excludeBoostsLink -}}#recent">exclude boosts</a>
                {{- else if .includeBoostsLink }}
                <a href="{{- .includeBoostsLink -}}#recent">include boosts</a>
                {{- end }}
                {{- if .rssFeed }}
                <a href="{{- .rssFeed -}}" class="rss-icon" aria-label="RSS feed">
                    <i class="fa fa-rss-square" aria-hidden="true"></i>
                </a>
                {{- end }}
            </div>
            {{- if not .galleryItems }}
            <div data-nosnippet class="nothinghere">
                {{- if .show_back_to_top }}
                    Reached the end of visible media!
                {{- else }}
                    Nothing to see here! {{ .account.Username }} has probably not posted any visible {{ template "webVisibility" . }} media yet.
                {{- end }}
            </div>
            {{- else }}
            <div
                class="media-gallery photoswipe-gallery"
                role="group"
            >
                {{- range $index, $attachment := .galleryItems }}
                {{- includeIndex "status_attachment.tmpl" $attachment $index | indent 4 }}
                {{- end }}
            </div>
            {{- end }}
            <nav class="backnextlinks">
                {{- if .show_back_to_top }}
                <a href="/@{{- .account.Username -}}">Back to top</a>
                {{- end }}
                {{- if .statuses_next }}
                <a href="{{- .statuses_next -}}" class="next">Show older</a>
                {{- end }}
            </nav>
        </section>
    </div>
    {{- end }}
</main>
{{- end }}