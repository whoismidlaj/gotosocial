{{- define "webVisibility" -}}
{{- with .account.WebVisibility -}}
{{- if eq . "public" -}}
public
{{- else if eq . "unlisted" -}}
public and unlisted
{{- end -}}
{{- end -}}
{{- end -}}

{{- with . }}
<main class="profile h-card">
    {{- with . }}
    {{- include "profile_header.tmpl" . | indent 1 }}
    {{- end }}
    {{- if eq .account.WebVisibility "none" }}
    {{- with . }}
    {{- include "profile_about_user.tmpl" . | indent 1 }}
    <section data-nosnippet class="nothinghere" aria-labelledby="postsby">
        <h3 id="postsby">Posts by <b>{{ .account.Username }}</b></h3>
        <p><b>{{ .account.Username }}</b> does not show posts on the World Wide Web.</p>
        <p>To see posts by <b>{{ .account.Username }}</b>, try pasting this profile URL into your fedi client of choice:</p>
        <pre class="language-url"><code class="language-url">{{- .account.URL -}}</code></pre>
    </section>
    {{- end }}
    {{- else }}
    <div class="column-split">
        {{- with . }}
        {{- include "profile_about_user.tmpl" . | indent 2 }}
        {{- end }}
        <div class="statuses-wrapper" role="region" aria-label="Posts by {{ .account.Username -}}">
            {{- if .pinned_statuses }}
            <section class="pinned statuses h-feed" aria-labelledby="pinned">
                <div class="col-header">
                    <h3 class="p-name" id="pinned">Pinned {{ template "webVisibility" . }} posts</h3>
                    <a href="#recent">jump to recent</a>
                </div>
                <div class="thread">
                    {{- range .pinned_statuses }}
                    <article
                        class="status expanded h-entry"
                        {{- includeAttr "status_attributes.tmpl" . | indentAttr 6  }}
                    >
                        {{- include "status.tmpl" . | indent 6 }}
                    </article>
                    {{- end }}
                </div>
            </section>
            {{- end }}
            <section class="recent statuses h-feed" aria-labelledby="recent">
                <div class="col-header wrapping">
                    <h3 class="p-name" id="recent">Recent {{ template "webVisibility" . }} posts</h3>
                    {{- if .excludeBoostsLink }}
                    <a href="{{- .excludeBoostsLink -}}#recent">exclude boosts</a>
                    {{- else if .includeBoostsLink }}
                    <a href="{{- .includeBoostsLink -}}#recent">include boosts</a>
                    {{- end }}
                    {{- if .rssFeed }}
                    <a href="{{- .rssFeed -}}" class="rss-icon" aria-label="RSS feed">
                        <i class="fa fa-rss-square" aria-hidden="true"></i>
                    </a>
                    {{- end }}
                </div>
                <div class="thread">
                    {{- if not .statuses }}
                    <div data-nosnippet class="nothinghere">
                        {{- if .show_back_to_top }}
                            Reached the end of visible {{ template "webVisibility" . }} posts!
                        {{- else }}
                            Nothing to see here! {{ .account.Username }} has probably not written any visible {{ template "webVisibility" . }} posts yet.
                        {{- end }}
                    </div>
                    {{- else }}
                    {{- range .statuses }}
                    <article
                        class="status expanded h-entry"
                        {{- includeAttr "status_attributes.tmpl" . | indentAttr 6  }}
                    >
                        {{- if isNil .Reblog }}
                        {{- include "status.tmpl" . | indent 6 }}
                        {{- else }}
                        <header class="status-header">
                            {{- include "status_header.tmpl" . | indent 7 }}
                        </header>
                        <div class="status-body text-cutoff">
                            <span class="text-cutoff">
                                <i class="fa fa-retweet" aria-hidden="true"></i>
                                <i class="text-cutoff">Boost of <span class="username text-cutoff">@{{- .Reblog.Account.Acct -}}</span></i>
                            </span>
                        </div>
                        <article
                            class="status reblog h-entry"
                            {{- includeAttr "status_attributes.tmpl" .Reblog | indentAttr 7  }}
                        >
                            {{- include "status.tmpl" .Reblog | indent 7 }}
                        </article>
                        {{- end }}
                    </article>
                    {{- end }}
                    {{- end }}
                </div>
                <nav class="backnextlinks">
                    {{- if .show_back_to_top }}
                    <a href="/@{{- .account.Username -}}">Back to top</a>
                    {{- end }}
                    {{- if .statuses_next }}
                    <a href="{{- .statuses_next -}}" class="next">Show older</a>
                    {{- end }}
                </nav>
            </section>
        </div>
    </div>
    {{- end }}
</main>
{{- end }}